PORT=3000
MONGODB_URI=mongodb://mongo:27017/hooksmith
REDIS_URL=redis://redis:6379
CONNECTORS_DIR=./connectors
DELIVERY_CONCURRENCY=5
REGENERATION_CONCURRENCY=2

# AI Engine configuration: 'openai' | 'gemini' | 'claude' | 'mcp'
AI_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini

# Google Gemini settings
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude settings
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# MCP Settings (used if AI_PROVIDER=mcp)
MCP_SERVER_URL=http://localhost:8000/sse
MCP_TOOL_NAME=generate_transformation

